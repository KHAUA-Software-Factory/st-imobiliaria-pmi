<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Forçar HTTPS (Compatível com Proxy e Balanceadores Locaweb)
  # Se o cabeçalho X-Forwarded-Proto não for https e a porta não for 443
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Feed XML público para Meta/Facebook (sem redirecionar para pasta)
  RewriteRule ^facebook$ /facebook.xml [L]
  RewriteRule ^facebook/$ /facebook.xml [L]
  RewriteRule ^facebook-commerce$ /facebook-commerce.xml [L]
  RewriteRule ^facebook-commerce/$ /facebook-commerce.xml [L]

  # 3. Regra para React Router
  # Se o pedido NÃO for para um arquivo real (-f) e NÃO for para uma pasta real (-d)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

AddType application/xml .xml

<IfModule mod_headers.c>
  <FilesMatch "\.xml$">
    Header set Content-Type "application/xml; charset=utf-8"
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>